{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    // Bun + Node compatibility
    "types": ["bun-types", "node"],
    "verbatimModuleSyntax": true,

    // Output (for Docker / prod)
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
